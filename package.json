{
  "name": "ngx-colors",
  "version": "3.6.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "lint": "ng lint",
    "prettify": "npx prettier --write '**/*.{ts,js,yaml,css,scss,json,md}'",
    "ci-prettify": "npx prettier --check '**/*.{ts,js,yaml,css,scss,json,md}'",
    "build-lib": "ng build --configuration production ngx-colors",
    "npm-pack": "cd dist/ngx-colors && npm pack",
    "package": "npm run build-lib && npm run npm-pack",
    "publishLib": "cp -f README.md dist/ngx-colors && cp -f README.md projects/ngx-colors && cd dist/ngx-colors && npm publish --access public",
    "XUX": "npm version minor && cd projects/ngx-colors && npm version minor",
    "XXU": "npm version patch && cd projects/ngx-colors && npm version patch",
    "BPP": "npm run package && npm run publishLib #BUILD PACKAGE n PUBLISH",
    "BFD": "ng build --configuration production ngx-color-examples && cd dist/ngx-color-examples && firebase deploy #BUILD n FIREBASE DEPLOY"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "ngx-highlightjs": "^14.0.1",
    "npm": "^11.17.0",
    "rxjs": "^7.5.5",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/language-service": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.4.5",
    "prettier": "^3.6.2",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-multiline-arrays": "^4.1.9",
    "ts-node": "~10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "^4.1.9"
  }
}
