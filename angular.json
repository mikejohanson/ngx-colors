{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-colors": {
      "projectType": "library",
      "root": "projects/ngx-colors",
      "sourceRoot": "projects/ngx-colors/src",
      "prefix": "ngx-colors",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/ngx-colors/tsconfig.lib.json",
            "project": "projects/ngx-colors/ng-package.json"
          },
          "configurations": {
            "production": {
              "project": "projects/ngx-colors/ng-package.json",
              "tsConfig": "projects/ngx-colors/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ngx-colors/tsconfig.spec.json",
            "buildTarget": "ngx-colors:build",
            "coverage": true,
            "coverageReporters": [
              "text",
              "lcov"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngx-colors/**/*.ts",
              "projects/ngx-colors/**/*.html"
            ]
          }
        }
      }
    },
    "ngx-color-examples": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ngx-color-examples",
      "sourceRoot": "projects/ngx-color-examples/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/ngx-color-examples"
            },
            "index": "projects/ngx-color-examples/src/index.html",
            "tsConfig": "projects/ngx-color-examples/tsconfig.app.json",
            "assets": [
              "projects/ngx-color-examples/src/favicon.ico",
              "projects/ngx-color-examples/src/google5eb9cb8e74ff5434.html",
              "projects/ngx-color-examples/src/assets",
              "projects/ngx-color-examples/src/app/examples"
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "projects/ngx-color-examples/src/styles.scss"
            ],
            "scripts": [],
            "extractLicenses": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true,
            "browser": "projects/ngx-color-examples/src/main.ts"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/ngx-color-examples/src/environments/environment.ts",
                  "with": "projects/ngx-color-examples/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "25kb"
                }
              ]
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "ngx-color-examples:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "ngx-color-examples:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "ngx-color-examples:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ngx-color-examples/tsconfig.spec.json",
            "buildTarget": "ngx-color-examples:build",
            "coverage": true,
            "coverageReporters": [
              "text",
              "lcov"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngx-color-examples/**/*.ts",
              "projects/ngx-color-examples/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "f0a0278b-fd65-4730-b6cc-109b254781b5"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
